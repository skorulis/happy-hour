# Copy to .env.production on the droplet (never commit secrets).
#   cp .env.production.example .env.production

# Postgres (Docker Compose; not exposed publicly — localhost bind only)
POSTGRES_USER=happyhour
POSTGRES_PASSWORD=change-me-to-a-long-random-string
POSTGRES_DB=happyhour

# Public site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://duskroute.com

# Auth (better-auth). Generate secret: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://duskroute.com

# Google OAuth — redirect URI: https://duskroute.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Maps (baked into the image at build time)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=
