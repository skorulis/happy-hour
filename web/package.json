{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "npm run prebuild && next build",
    "prebuild": "node -e \"const fs=require('node:fs');const src='../data';const dest='./data';if(fs.existsSync(src)){fs.cpSync(src,dest,{recursive:true,force:true});}else if(!fs.existsSync(dest)){throw new Error('data/ missing: run from monorepo root or copy ../data into web/data');}\"",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "sync": "tsx scripts/sync-sqlite.ts",
    "sync:prod": "tsx scripts/sync-prod.ts",
    "import-suburbs": "tsx scripts/import-suburbs.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1091.0",
    "@lucide/lab": "^0.1.2",
    "@sentry/nextjs": "^10.66.0",
    "@vis.gl/react-google-maps": "^1.8.3",
    "better-auth": "^1.6.23",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.22.0",
    "next": "16.2.9",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-dropzone": "^19.1.1",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "yet-another-react-lightbox": "^3.32.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "better-sqlite3": "^12.11.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
