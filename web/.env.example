# Canonical production URL (no trailing slash). Used for sitemap, robots, and metadataBase.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Auth (better-auth). Generate secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (sign in with Google). Redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Maps (search map view). Enable Maps JavaScript API and create a Map ID in Google Cloud.
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=

# PostgreSQL connection (local Docker)
DATABASE_URL=postgresql://happyhour:happyhour@localhost:5433/happyhour

# Production Postgres (Neon). Copy to .env.production.local for `npm run sync:prod`.
# DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Path to DealScraper SQLite database (macOS sandbox)
# Default when running outside sandbox during development:
# SQLITE_PATH=~/Documents/db.sqlite
#
# Sandboxed app path (adjust if bundle ID changes):
# SQLITE_PATH=~/Library/Containers/com.skorulis.DealScraper/Data/Documents/db.sqlite
SQLITE_PATH=
