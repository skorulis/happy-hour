# Canonical production URL (no trailing slash). Used for sitemap, robots, and metadataBase.
# NEXT_PUBLIC_SITE_URL=https://duskroute.com

# Auth (better-auth). Generate secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (sign in with Google). Redirect URI: http://localhost:3000/api/auth/callback/google
# Production redirect URI: https://duskroute.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Maps (search map view). Enable Maps JavaScript API and create a Map ID in Google Cloud.
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=

# Amplitude (server-side analytics proxy — never expose as NEXT_PUBLIC_*)
# AMPLITUDE_API_KEY=

# OpenRouter (server-side deal extraction proxy — never expose as NEXT_PUBLIC_*)
# OPENROUTER_API_KEY=

# PostgreSQL connection (local Docker — see docker-compose.yml)
DATABASE_URL=postgresql://happyhour:happyhour@localhost:5433/happyhour

# Production Postgres (DigitalOcean droplet). For `npm run sync:prod`, open an SSH
# tunnel first (Postgres is bound to localhost on the server only):
#
#   ssh -L 5433:127.0.0.1:5432 user@DROPLET_IP
#
# Then copy this to `.env.production.local` with the same user/password as the
# droplet's `.env.production`:
#
# DATABASE_URL=postgresql://happyhour:YOUR_PASSWORD@localhost:5433/happyhour

# Path to DealScraper SQLite database (macOS sandbox)
# Default when running outside sandbox during development:
# SQLITE_PATH=~/Documents/db.sqlite
#
# Sandboxed app path (adjust if bundle ID changes):
# SQLITE_PATH=~/Library/Containers/com.skorulis.DealScraper/Data/Documents/db.sqlite
SQLITE_PATH=
