# PostgreSQL connection (local Docker)
DATABASE_URL=postgresql://happyhour:happyhour@localhost:5433/happyhour

# Path to DealScraper SQLite database (macOS sandbox)
# Default when running outside sandbox during development:
# SQLITE_PATH=~/Documents/db.sqlite
#
# Sandboxed app path (adjust if bundle ID changes):
# SQLITE_PATH=~/Library/Containers/com.skorulis.DealScraper/Data/Documents/db.sqlite
SQLITE_PATH=
