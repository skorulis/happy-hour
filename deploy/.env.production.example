# Copy to .env.production on the droplet (never commit secrets).
#   cp .env.production.example .env.production
#
# Lives at: /opt/happy-hour/deploy/.env.production

# Image locations (overridden by deploy CI for IMAGE_TAG / repos)
WEB_IMAGE_REPO=ghcr.io/skorulis/happy-hour-web
MIGRATE_IMAGE_REPO=ghcr.io/skorulis/happy-hour-migrate
IMAGE_TAG=latest

# Postgres (bound to localhost only on the host).
# Use a URL-safe password (hex/alphanumeric only) — it is embedded in DATABASE_URL.
# Bootstrap generates: openssl rand -hex 24
POSTGRES_USER=happyhour
POSTGRES_PASSWORD=change-me-to-a-long-random-string
POSTGRES_DB=happyhour
DATABASE_URL=postgresql://happyhour:change-me-to-a-long-random-string@postgres:5432/happyhour

# Public site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://duskroute.com

# Auth (better-auth). Generate secret: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://duskroute.com

# Google OAuth — redirect URI: https://duskroute.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend (email verification). Verify mail.duskroute.com in Resend; DNS in Cloudflare.
RESEND_API_KEY=
EMAIL_FROM=DuskRoute <noreply@mail.duskroute.com>

# Google Maps (also baked into the image at CI build time via GitHub secrets)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=

# Amplitude (server-side analytics proxy — never expose as NEXT_PUBLIC_*)
AMPLITUDE_API_KEY=

# OpenRouter (server-side deal extraction proxy — never expose as NEXT_PUBLIC_*)
OPENROUTER_API_KEY=

# Cloudflare R2 (user-uploaded deal creatives — never expose as NEXT_PUBLIC_*)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=duskroute-heroes
R2_PUBLIC_BASE_URL=https://images.duskroute.com
